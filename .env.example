# Flask Configuration

FLASK_ENV=development
SECRET_KEY=your_secret_key_here

# ──────────────────────────────────────────────────────
# Email Notification Configuration (Issue #499)
# Used by services/email_service.py to send achievement
# notifications to students via SMTP.
#
# Gmail example:
#   MAIL_SERVER=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_USE_TLS=true
#   MAIL_USERNAME=your_gmail_address@gmail.com
#   MAIL_PASSWORD=your_app_password   ← generate at myaccount.google.com/apppasswords
#
# Leave MAIL_USERNAME / MAIL_PASSWORD blank to disable
# notifications (the app will log a warning but not crash).
# ──────────────────────────────────────────────────────

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SENDER=Achievement Management System <noreply@example.com>

